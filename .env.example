# Copy to .env and fill in. Never commit .env.

# --- Option A: OpenAI API (preferred when billing is available) ---
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_MODEL=gpt-5.6
# (leave OPENAI_BASE_URL unset)

# --- Option B: Gemini free tier via OpenAI-compatible endpoint ---
# Get a free key at https://aistudio.google.com (no card required).
OPENAI_API_KEY=your-gemini-key-here
OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
OPENAI_MODEL=gemini-2.5-flash

SIKA_DB=data/processed/sika.db
